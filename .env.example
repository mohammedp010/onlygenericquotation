# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=onlygeneric

# For TiDB Cloud or other SSL-required databases (uncomment for production):
# DB_SSL=true
# DB_SSL_CA=/etc/ssl/certs/ca-certificates.crt
# DB_SSL_REJECT_UNAUTHORIZED=true

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8080

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Change this to a long random secret string in production
JWT_SECRET=onlygeneric_super_secret_jwt_key_change_me
